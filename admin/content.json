  "cbam": {
    "hero": {
      "eyebrow": {
        "en": "Carbon Border Adjustment Mechanism",
        "es": "",
        "pt": ""
      },
      "h1": {
        "en": "CBAM is coming. Be positioned, not penalised.",
        "es": "",
        "pt": ""
      },
      "p": {
        "en": "The EU's carbon border tariff reshapes the economics of every carbon-intensive export. Equiterra turns that exposure into a strategy.",
        "es": "",
        "pt": ""
      }
    },
    "basics": {
      "eyebrow": {
        "en": "The basics",
        "es": "",
        "pt": ""
      },
      "h2": {
        "en": "What CBAM actually means",
        "es": "",
        "pt": ""
      },
      "lead": {
        "en": "CBAM puts a carbon price on imports into the EU, starting with carbon-intensive goods, to match the cost EU producers already pay. Exporters that can measure, reduce and document emissions win; those that can't, pay.",
        "es": "",
        "pt": ""
      },
      "cards": [
        {
          "h3": {
            "en": "Who it hits",
            "es": "",
            "pt": ""
          },
          "p": {
            "en": "Iron, steel, aluminium, cement, fertilisers, hydrogen and electricity, first, with scope expanding.",
            "es": "",
            "pt": ""
          }
        },
        {
          "h3": {
            "en": "What changes",
            "es": "",
            "pt": ""
          },
          "p": {
            "en": "Importers must report embedded emissions and, from 2026, buy CBAM certificates for them.",
            "es": "",
            "pt": ""
          }
        },
        {
          "h3": {
            "en": "The opportunity",
            "es": "",
            "pt": ""
          },
          "p": {
            "en": "Accurate MRV and decarbonisation become a competitive moat, not just a cost.",
            "es": "",
            "pt": ""
          }
        }
      ]
    },
    "timeline": [
      {
        "date": "2023–25",
        "h3": {
          "en": "Transitional phase",
          "es": "",
          "pt": ""
        },
        "p": {
          "en": "Quarterly reporting of embedded emissions, no financial payment yet, but the data foundation is set.",
          "es": "",
          "pt": ""
        }
      },
      {
        "date": "2026",
        "h3": {
          "en": "Definitive regime begins",
          "es": "",
          "pt": ""
        },
        "p": {
          "en": "Importers start purchasing CBAM certificates for embedded emissions. Real cost enters the equation.",
          "es": "",
          "pt": ""
        }
      },
      {
        "date": "2027–33",
        "h3": {
          "en": "Free-allowance phase-out",
          "es": "",
          "pt": ""
        },
        "p": {
          "en": "EU ETS free allowances wind down as CBAM scales, exposure rises for unprepared exporters.",
          "es": "",
          "pt": ""
        }
      },
      {
        "date": "Beyond",
        "h3": {
          "en": "Scope expansion",
          "es": "",
          "pt": ""
        },
        "p": {
          "en": "More sectors and indirect emissions are brought in. Early positioning compounds.",
          "es": "",
          "pt": ""
        }
      }
    ],
    "role": {
      "eyebrow": {
        "en": "Our role",
        "es": "",
        "pt": ""
      },
      "h2": {
        "en": "How Equiterra positions you",
        "es": "",
        "pt": ""
      },
      "p": {
        "en": "We turn CBAM from a compliance scramble into a strategic advantage, measuring what matters, reducing what counts, and documenting what regulators require.",
        "es": "",
        "pt": ""
      },
      "li": [
        "Embedded-emissions measurement & MRV",
        "Exposure modelling & cost forecasting",
        "Decarbonisation & offset strategy",
        "Reporting & certificate management"
      ]
    },
    "faq": [
      {
        "q": {
          "en": "Does CBAM affect my business if I'm outside the EU?",
          "es": "",
          "pt": ""
        },
        "a": {
          "en": "Yes, if you export covered goods into the EU, your importers carry the CBAM obligation, and they will pass the data and cost requirements back to you.",
          "es": "",
          "pt": ""
        }
      },
      {
        "q": {
          "en": "What happens if I can't document my emissions?",
          "es": "",
          "pt": ""
        },
        "a": {
          "en": "Default values apply, and they are deliberately conservative (high). Accurate MRV almost always lowers your effective CBAM cost.",
          "es": "",
          "pt": ""
        }
      },
      {
        "q": {
          "en": "Can carbon credits offset CBAM exposure?",
          "es": "",
          "pt": ""
        },
        "a": {
          "en": "CBAM itself is about embedded emissions, but a well-structured decarbonisation and carbon strategy reduces both your real footprint and your certificate burden. We design both together.",
          "es": "",
          "pt": ""
        }
      },
      {
        "q": {
          "en": "When should we start preparing?",
          "es": "",
          "pt": ""
        },
        "a": {
          "en": "Now. The transitional phase is the cheap window to build the data and processes before certificates become payable.",
          "es": "",
          "pt": ""
        }
      }
    ]
  },
